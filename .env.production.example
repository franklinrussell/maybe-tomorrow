# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Your production domain — no trailing slash
# On Vercel this is set automatically, but set it explicitly to be safe
NEXTAUTH_URL=https://your-domain.vercel.app

# ─── onejsonfile.com tokens ──────────────────────────────────────────────────
# Create one token per collection at https://onejsonfile.com
# Each token holds a separate JSON document
ONEJSONFILE_USERS_TOKEN=      # stores { [userId]: User }
ONEJSONFILE_TASKS_TOKEN=      # stores { [userId]: Task[] }
ONEJSONFILE_SESSIONS_TOKEN=   # stores { [sessionToken]: { userId, expires } }
ONEJSONFILE_AUTH_TOKEN=       # stores OAuth accounts + email verification tokens

# ─── Email magic link (Resend SMTP) ──────────────────────────────────────────
# Format: smtp://resend:YOUR_RESEND_API_KEY@smtp.resend.com:587
EMAIL_SERVER=smtp://resend:YOUR_RESEND_API_KEY@smtp.resend.com:587

# Must be a verified sender domain in your Resend account
EMAIL_FROM=noreply@yourdomain.com

# ─── AI (optional) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
